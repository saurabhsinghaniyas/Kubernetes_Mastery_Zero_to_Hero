---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: mongo-express
spec:
  serviceName: "mongo-express"
  replicas: 1 # Usually 1 is enough for a UI, but you can increase this
  selector:
    matchLabels:
      app: mongo-express
  template:
    metadata:
      labels:
        app: mongo-express
    spec:
      containers:
      - name: mongo-express
        # Using the fully qualified name to avoid the JFrog pull error we saw
        image: docker.io/library/mongo-express:latest
        ports:
        - containerPort: 8081
        env:
        - name: ME_CONFIG_MONGODB_ADMINUSERNAME
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-username
        - name: ME_CONFIG_MONGODB_ADMINPASSWORD
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-password
        - name: ME_CONFIG_MONGODB_URL
          # Connection string for your MongoDB StatefulSet
          # Format: mongodb://<user>:<pass>@<service-name>:27017
          value: "mongodb://mongoadmin:password123@mongodb-internal:27017/"
        - name: ME_CONFIG_MONGODB_SERVER
          value: "mongodb-internal"
        resources:
          requests:
            cpu: "100m"
            memory: "128Mi"
          limits:
            cpu: "500m"
            memory: "256Mi"    
